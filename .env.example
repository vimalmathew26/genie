# Copy this file to .env and fill in real values. Never commit .env.

# Required - OpenRouter API key, used for all LLM calls (config.py, llm_client.py,
# vision_mixin.py, scratchpad_writer.py).
OPENROUTER_API_KEY=

# Required for GitHub actions (open_pr, create_repo, and 40+ other GitHub REST
# operations in github_actions.py). Needs repo scope at minimum.
GITHUB_TOKEN=

# Optional - Telegram bot token/chat ID for progress notifications and the
# Human Review Pipeline (review_bot.py, orchestrator.py). Leave blank to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional - master switch for the Post-Subtask Verifier. Defaults to "1" (on)
# when unset. Set to "0" to disable (config.py).
GENIE_VERIFY=1

# Test-suite only - a scratch repo (owner/repo) genie_phase5.py's T36/T37 tests
# push to. Not needed to run Genie itself, only to run the Phase 5 test suite.
GITHUB_TEST_REPO=
